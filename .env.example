# --- Auth ---
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# GitHub OAuth app -> https://github.com/settings/developers
# Homepage:     http://localhost:3000
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# --- Database (Neon Postgres) ---
# Create a free project at https://neon.tech, then copy the connection strings
# from "Connection Details" -> "Pooled connection" (DATABASE_URL) and
# "Direct connection" (DIRECT_URL).
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
DIRECT_URL=postgres://user:pass@host/db?sslmode=require
